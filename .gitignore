###############################################################################
# Organization-wide .gitignore
# Focus: R / Quarto / Analytics / Data Science
# Policy: Do NOT commit data, rendered outputs, caches, environments, or
#          machine/user-specific artifacts.
###############################################################################

###############################################################################
# --- Operating system / editor noise -----------------------------------------
###############################################################################
.DS_Store
Thumbs.db
desktop.ini
*Zone.Identifier

.vscode/
.idea/
*.swp
*.swo
*~

###############################################################################
# --- R / RStudio --------------------------------------------------------------
###############################################################################
.Rproj.user/
.Rhistory
.Rapp.history
.RData
.Rdata
.RDataTmp
.Ruserdata
.Rprofile
.Renviron
.httr-oauth

rsconnect/
shiny-logs/

# R CMD build / check
*.tar.gz
*.Rcheck/
*-Ex.R

# renv (ignore everything except the lock + activator)
renv/
!renv.lock
!renv/activate.R

###############################################################################
# --- Quarto / R Markdown / Knitr ----------------------------------------------
###############################################################################
.quarto/
**/.quarto/
*_cache/
cache/
*.utf8.md
*.knit.md

# Rendered outputs (policy: do not commit)
_site/
_site_libs/
docs/
*.html
*.pdf
*.docx
*.pptx

# Quarto / Rmd auxiliary folders
*_files/
*_libs/
**/*.quarto_ipynb

###############################################################################
# --- Python -------------------------------------------------------------------
###############################################################################
__pycache__/
*.py[cod]
*.pyo
*.pyd

.venv/
venv/
env/
pip-wheel-metadata/

###############################################################################
# --- Data files (NOT typically version controlled) ---------------------------
###############################################################################
# Flat files
*.csv
*.tsv
*.xlsx
*.xls
*.rpt
*.zip

# Binary / media
*.jpeg
*.jpg
*.png
*.tiff
*.gif

# Common data directories
data/
data_raw/
data-raw/
data_tmp/
archive/
csv/

###############################################################################
# --- Databases / intermediate artifacts --------------------------------------
###############################################################################
*.sqlite
*.sqlite3
*.db
*.duckdb
*.parquet
*.feather
*.fst
*.rds

###############################################################################
# --- Logs / temp / scratch ----------------------------------------------------
###############################################################################
*.log
*.tmp
*.bak
*.old

sandbox/
staging/
local/
cellar/
lock/
library/
python/

###############################################################################
# --- Documentation build artifacts -------------------------------------------
###############################################################################
inst/doc
vignettes/*.html
vignettes/*.pdf
_site/
docs/

###############################################################################
# --- Environment / secrets ----------------------------------------------------
###############################################################################
.env
.env.*
config.yml

###############################################################################
# --- SQL / misc analytics -----------------------------------------------------
###############################################################################
*.lua
*.typ

###############################################################################
# --- Explicit allow-list examples --------------------------------------------
###############################################################################
# If a project intentionally versions data or outputs, override locally:
#   !data/example_small.csv
#   !docs/index.html
###############################################################################
